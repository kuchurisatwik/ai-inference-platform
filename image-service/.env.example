# Copy to .env and adjust. Defaults run the mock backend (no GPU required).

# "mock" for local dev, "flux" on the GPU EC2 box
MODEL_BACKEND=mock
MODEL_PATH=/opt/models/flux

# Storage — leave S3_BUCKET empty to save to ./outputs locally
AWS_REGION=us-east-1
S3_BUCKET=
S3_PUBLIC_BASE_URL=

OUTPUT_FOLDER=outputs
LOG_LEVEL=INFO
