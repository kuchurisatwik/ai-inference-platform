# Copy to .env and adjust. Defaults run the mock backend (no GPU required).

# "mock" for local dev, "flux" on the GPU EC2 box
MODEL_BACKEND=mock
MODEL_PATH=/opt/models/flux

# Storage — leave S3_BUCKET empty to save to ./outputs locally
AWS_REGION=us-east-1
S3_BUCKET=
S3_PUBLIC_BASE_URL=
# Return time-limited pre-signed URLs instead of public ones (Phase 6)
S3_PRESIGN=false
S3_URL_EXPIRY=3600

OUTPUT_FOLDER=outputs
LOG_LEVEL=INFO

# Require callers to send one of these keys in the X-API-Key header.
# Comma-separated. Leave empty to disable auth. e.g. API_KEYS=sk-abc123,sk-def456
API_KEYS=
